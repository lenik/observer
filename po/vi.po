#: src/oremind.cpp:108
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"Cách sử dụng: oremind [TÙY CHỌN]...\n"
"Chạy lời nhắc tự quan sát trên màn hình ở chế độ nền.\n"

#: src/oremind.cpp:113
msgid "repeat for more verbose loggings\n"
msgstr "lap lai de hien thi nhieu nhat ky chi tiet hon\n"

#: src/oremind.cpp:115
msgid "show less logging messages\n"
msgstr "hien thi it thong diep nhat ky hon\n"

#: src/oremind.cpp:117
msgid "display this help and exit\n"
msgstr "hiển thị trợ giúp này và thoát\n"

#: src/oremind.cpp:119
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr "đặt giao diện người dùng cục bộ, ví dụ zh_CN, ja, ko, en\n"

#: src/oremind.cpp:121
msgid "set theme: light or dark\n"
msgstr "đặt chủ đề: sáng hoặc tối\n"

#: src/oremind.cpp:123
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "đặt phần trăm độ mờ cuối cùng của hộp thoại, từ 0 đến 100\n"

#: src/oremind.cpp:125
msgid "set prompt interval in minutes\n"
msgstr "đặt khoảng thời gian nhắc nhở tính bằng phút\n"

#: src/oremind.cpp:127
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr "đặt ngày bắt đầu tuần của lịch: M/m là thứ Hai, S/s là Chủ nhật\n"

#: src/oremind.cpp:129
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr "Đường dẫn tệp SQLite hoặc thư mục nhật ký khi PATH là một thư mục\n"

#: src/oremind.cpp:131
msgid "output version information and exit\n"
msgstr "in thông tin phiên bản và thoát\n"

#: src/oremind.cpp:133
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Báo lỗi tới: <%s>\n"

#: src/oremind.cpp:179
#, c-format
msgid "invalid locale: %s\n"
msgstr "locale không hợp lệ: %s\n"

#: src/oremind.cpp:187
#, c-format
msgid "expect theme name.\n"
msgstr "cần tên chủ đề.\n"

#: src/oremind.cpp:193
#, c-format
msgid "invalid theme: %s\n"
msgstr "chủ đề không hợp lệ: %s\n"

#: src/oremind.cpp:204
#, c-format
msgid "invalid opacity: %s\n"
msgstr "độ mờ không hợp lệ: %s\n"

#: src/oremind.cpp:215
#, c-format
msgid "invalid interval: %s\n"
msgstr "khoảng thời gian không hợp lệ: %s\n"

#: src/oremind.cpp:227
#, c-format
msgid "invalid week start: %s\n"
msgstr "ngày bắt đầu tuần không hợp lệ: %s\n"

#: src/oremind.cpp:236
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "Bản quyền (C) %d %s\n"

#: src/oremind.cpp:237
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"Giấy phép AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:239
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "Đây là phần mềm tự do: bạn có thể sửa đổi và phân phối lại.\n"

#: src/oremind.cpp:241
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "Dự án này phản đối bóc lột AI và bá quyền AI.\n"

#: src/oremind.cpp:242
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"Dự án này bác bỏ kiểu cấp phép MIT máy móc và kiểu cấp phép BSD ngây ngô về "
"chính trị.\n"

#: src/oremind.cpp:245
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "KHÔNG CÓ BẤT KỲ BẢO HÀNH nào trong phạm vi luật cho phép.\n"

