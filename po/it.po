#: src/oremind.cpp:108
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"Utilizzo: oremind [OPZIONE]...\n"
"Esegui un messaggio di auto-osservazione del desktop in background.\n"

#: src/oremind.cpp:113
msgid "repeat for more verbose loggings\n"
msgstr "ripeti per ottenere log piu verbosi\n"

#: src/oremind.cpp:115
msgid "show less logging messages\n"
msgstr "mostra meno messaggi di log\n"

#: src/oremind.cpp:117
msgid "display this help and exit\n"
msgstr "mostra questo aiuto ed esce\n"

#: src/oremind.cpp:119
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr "imposta l'interfaccia utente locale, ad esempio zh_CN, ja, ko, en\n"

#: src/oremind.cpp:121
msgid "set theme: light or dark\n"
msgstr "imposta il tema: chiaro o scuro\n"

#: src/oremind.cpp:123
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "imposta la percentuale finale di opacità della finestra, da 0 a 100\n"

#: src/oremind.cpp:125
msgid "set prompt interval in minutes\n"
msgstr "impostare l'intervallo di richiesta in minuti\n"

#: src/oremind.cpp:127
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr ""
"imposta l’inizio settimana del calendario: M/m per lunedì, S/s per domenica\n"

#: src/oremind.cpp:129
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr ""
"Percorso del file SQLite o directory di registro quando PATH è una "
"directory\n"

#: src/oremind.cpp:131
msgid "output version information and exit\n"
msgstr "mostra le informazioni di versione ed esce\n"

#: src/oremind.cpp:133
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Segnala bug a: <%s>\n"

#: src/oremind.cpp:179
#, c-format
msgid "invalid locale: %s\n"
msgstr "locale non valida: %s\n"

#: src/oremind.cpp:187
#, c-format
msgid "expect theme name.\n"
msgstr "nome del tema atteso.\n"

#: src/oremind.cpp:193
#, c-format
msgid "invalid theme: %s\n"
msgstr "tema non valido: %s\n"

#: src/oremind.cpp:204
#, c-format
