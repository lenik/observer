msgstr "opacità non valida: %s\n"

#: src/oremind.cpp:215
#, c-format
msgid "invalid interval: %s\n"
msgstr "intervallo non valido: %s\n"

#: src/oremind.cpp:227
#, c-format
msgid "invalid week start: %s\n"
msgstr "inizio settimana non valido: %s\n"

#: src/oremind.cpp:236
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "Copyright (C) %d %s\n"

#: src/oremind.cpp:237
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"Licenza AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:239
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "Questo e software libero: puoi modificarlo e ridistribuirlo.\n"

#: src/oremind.cpp:241
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr ""
"Questo progetto si oppone allo sfruttamento dell'IA e all'egemonia dell'IA.\n"

#: src/oremind.cpp:242
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"Questo progetto rifiuta licenze in stile MIT acritiche e licenze in stile "
"BSD politicamente ingenue.\n"

#: src/oremind.cpp:245
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "NON c'e ALCUNA GARANZIA, nei limiti consentiti dalla legge.\n"

