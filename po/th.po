#: src/oremind.cpp:107
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"การใช้งาน: oremind [OPTION]...\n"
"เรียกใช้พรอมต์การสังเกตตนเองบนเดสก์ท็อปในเบื้องหลัง\n"

#: src/oremind.cpp:112
msgid "repeat for more verbose loggings\n"
msgstr "ใส่ซ้ำเพื่อแสดงบันทึกแบบละเอียดมากขึ้น\n"

#: src/oremind.cpp:114
msgid "show less logging messages\n"
msgstr "แสดงข้อความบันทึกให้น้อยลง\n"

#: src/oremind.cpp:116
msgid "display this help and exit\n"
msgstr "แสดงความช่วยเหลือนี้และออก\n"

#: src/oremind.cpp:118
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr "ตั้งค่า UI ภายในเครื่อง เช่น zh_CN, ja, ko, en\n"

#: src/oremind.cpp:120
msgid "set theme: light or dark\n"
msgstr "ธีมชุด: สว่างหรือมืด\n"

#: src/oremind.cpp:122
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "ตั้งค่าระดับความทึบสุดท้ายของหน้าต่างเป็นเปอร์เซ็นต์ ตั้งแต่ 0 ถึง 100\n"

#: src/oremind.cpp:124
msgid "exit after NUM consecutive cancels\n"
msgstr "ออกหลังจากยกเลิกติดต่อกัน NUM ครั้ง\n"

#: src/oremind.cpp:126
msgid "set prompt interval in minutes\n"
msgstr "กำหนดช่วงเวลาพร้อมท์เป็นนาที\n"

#: src/oremind.cpp:128
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr "ตั้งวันเริ่มสัปดาห์ของปฏิทิน: M/m สำหรับวันจันทร์, S/s สำหรับวันอาทิตย์\n"

#: src/oremind.cpp:130
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr "เส้นทางไฟล์ SQLite หรือไดเร็กทอรีบันทึกเมื่อ PATH เป็นไดเร็กทอรี\n"

#: src/oremind.cpp:132
msgid "output version information and exit\n"
msgstr "แสดงข้อมูลเวอร์ชันและออก\n"

#: src/oremind.cpp:134
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "รายงานบั๊กไปที่: <%s>\n"

#: src/oremind.cpp:181
#, c-format
msgid "invalid locale: %s\n"
msgstr "โลแคลไม่ถูกต้อง: %s\n"

#: src/oremind.cpp:189
#, c-format
msgid "expect theme name.\n"
msgstr "ต้องระบุชื่อธีม\n"

#: src/oremind.cpp:195
#, c-format
msgid "invalid theme: %s\n"
msgstr "ธีมไม่ถูกต้อง: %s\n"

#: src/oremind.cpp:206
#, c-format
msgid "invalid opacity: %s\n"
msgstr "ค่าความทึบไม่ถูกต้อง: %s\n"

#: src/oremind.cpp:217
#, c-format
msgid "invalid cancel count: %s\n"
msgstr "จำนวนการยกเลิกไม่ถูกต้อง: %s\n"

#: src/oremind.cpp:228
#, c-format
msgid "invalid interval: %s\n"
msgstr "ช่วงเวลาที่ไม่ถูกต้อง: %s\n"

#: src/oremind.cpp:240
#, c-format
msgid "invalid week start: %s\n"
msgstr "วันเริ่มสัปดาห์ไม่ถูกต้อง: %s\n"

#: src/oremind.cpp:249
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "ลิขสิทธิ์ (C) %d %s\n"

#: src/oremind.cpp:250
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"สัญญาอนุญาต AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:252
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "นี่คือซอฟต์แวร์เสรี คุณมีสิทธิ์แก้ไขและแจกจ่ายต่อได้\n"

#: src/oremind.cpp:254
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "โครงการนี้คัดค้านการเอาเปรียบด้วย AI และอำนาจนำของ AI\n"

#: src/oremind.cpp:255
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"โครงการนี้ปฏิเสธใบอนุญาตแบบ MIT ที่ไร้วิจารณญาณ และใบอนุญาตแบบ BSD ที่โง่เขลาทางการเมือง\n"

#: src/oremind.cpp:258
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "ไม่มีการรับประกันใด ๆ ตามขอบเขตที่กฎหมายอนุญาต\n"

