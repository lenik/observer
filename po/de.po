#: src/oremind.cpp:108
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"Verwendung: oremind [OPTION]...\n"
"Führen Sie im Hintergrund eine Desktop-Selbstbeobachtungsaufforderung aus.\n"

#: src/oremind.cpp:113
msgid "repeat for more verbose loggings\n"
msgstr "wiederholen fuer ausfuehrlichere Protokollmeldungen\n"

#: src/oremind.cpp:115
msgid "show less logging messages\n"
msgstr "weniger Protokollmeldungen anzeigen\n"

#: src/oremind.cpp:117
msgid "display this help and exit\n"
msgstr "diese Hilfe anzeigen und beenden\n"

#: src/oremind.cpp:119
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr ""
"Legen Sie die lokale Benutzeroberfläche fest, zum Beispiel zh_CN, ja, ko, "
"en\n"

#: src/oremind.cpp:121
msgid "set theme: light or dark\n"
msgstr "Thema einstellen: hell oder dunkel\n"

#: src/oremind.cpp:123
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "endgültige Dialogdeckkraft in Prozent von 0 bis 100 festlegen\n"

#: src/oremind.cpp:125
msgid "set prompt interval in minutes\n"
msgstr "Stellen Sie das Aufforderungsintervall in Minuten ein\n"

#: src/oremind.cpp:127
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr "Kalender-Wochenbeginn festlegen: M/m für Montag, S/s für Sonntag\n"

#: src/oremind.cpp:129
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr ""
"SQLite-Dateipfad oder Protokollverzeichnis, wenn PATH ein Verzeichnis ist\n"

#: src/oremind.cpp:131
msgid "output version information and exit\n"
msgstr "Versionsinformationen anzeigen und beenden\n"

#: src/oremind.cpp:133
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Fehler melden an: <%s>\n"

#: src/oremind.cpp:179
#, c-format
msgid "invalid locale: %s\n"
msgstr "Ungültige Locale: %s\n"

#: src/oremind.cpp:187
#, c-format
msgid "expect theme name.\n"
msgstr "Themenname erwartet.\n"

#: src/oremind.cpp:193
#, c-format
msgid "invalid theme: %s\n"
msgstr "Ungültiges Thema: %s\n"

#: src/oremind.cpp:204
#, c-format
msgid "invalid opacity: %s\n"
msgstr "Ungültige Deckkraft: %s\n"

#: src/oremind.cpp:215
#, c-format
msgid "invalid interval: %s\n"
msgstr "Ungültiges Intervall: %s\n"

#: src/oremind.cpp:227
#, c-format
msgid "invalid week start: %s\n"
msgstr "ungültiger Wochenbeginn: %s\n"

#: src/oremind.cpp:236
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "Copyright (C) %d %s\n"

#: src/oremind.cpp:237
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"Lizenz AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:239
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "Dies ist freie Software: Sie duerfen sie aendern und weitergeben.\n"

#: src/oremind.cpp:241
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "Dieses Projekt lehnt KI-Ausbeutung und KI-Hegemonie ab.\n"

#: src/oremind.cpp:242
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"Dieses Projekt lehnt gedankenlose MIT-artige Lizenzen und politisch naive "
"BSD-artige Lizenzen ab.\n"

#: src/oremind.cpp:245
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "Es gibt KEINE GARANTIE, soweit gesetzlich zulaessig.\n"

