#: src/oremind.cpp:108
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"사용법: oremind [OPTION]...\n"
"데스크톱 자기 관찰 프롬프트를 백그라운드에서 실행합니다.\n"

#: src/oremind.cpp:113
msgid "repeat for more verbose loggings\n"
msgstr "더 자세한 로그를 보려면 반복 지정\n"

#: src/oremind.cpp:115
msgid "show less logging messages\n"
msgstr "로그 메시지를 더 적게 표시\n"

#: src/oremind.cpp:117
msgid "display this help and exit\n"
msgstr "이 도움말을 표시하고 종료\n"

#: src/oremind.cpp:119
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr "로컬 UI 설정(예: zh_CN, ja, ko, en)\n"

#: src/oremind.cpp:121
msgid "set theme: light or dark\n"
msgstr "테마 설정: light 또는 dark\n"

#: src/oremind.cpp:123
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "최종 대화상자 불투명도를 0에서 100 사이의 백분율로 설정\n"

#: src/oremind.cpp:125
msgid "exit after NUM consecutive cancels\n"
msgstr "연속 취소 NUM회 후 종료\n"

#: src/oremind.cpp:127
msgid "set prompt interval in minutes\n"
msgstr "프롬프트 간격을 분 단위로 설정\n"

#: src/oremind.cpp:129
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr "달력 주 시작일 설정: M/m은 월요일, S/s는 일요일\n"

#: src/oremind.cpp:131
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr "SQLite 파일 경로. PATH가 디렉터리이면 로그 저장 위치\n"

#: src/oremind.cpp:133
msgid "output version information and exit\n"
msgstr "버전 정보를 표시하고 종료\n"

#: src/oremind.cpp:135
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "버그 제보: <%s>\n"

#: src/oremind.cpp:182
#, c-format
msgid "invalid locale: %s\n"
msgstr "잘못된 로캘: %s\n"

#: src/oremind.cpp:190
#, c-format
msgid "expect theme name.\n"
msgstr "테마 이름이 필요합니다.\n"

#: src/oremind.cpp:196
#, c-format
msgid "invalid theme: %s\n"
msgstr "잘못된 테마: %s\n"

#: src/oremind.cpp:207
#, c-format
msgid "invalid opacity: %s\n"
msgstr "잘못된 불투명도: %s\n"

#: src/oremind.cpp:218
#, c-format
msgid "invalid cancel count: %s\n"
msgstr "잘못된 취소 횟수: %s\n"

#: src/oremind.cpp:229
#, c-format
msgid "invalid interval: %s\n"
msgstr "잘못된 간격: %s\n"

#: src/oremind.cpp:241
#, c-format
msgid "invalid week start: %s\n"
msgstr "잘못된 주 시작일: %s\n"

#: src/oremind.cpp:250
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "저작권 (C) %d %s\n"

#: src/oremind.cpp:251
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"라이선스 AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:253
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "이것은 자유 소프트웨어이며 자유롭게 변경하고 재배포할 수 있습니다.\n"

#: src/oremind.cpp:255
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "이 프로젝트는 AI 착취와 AI 패권에 반대합니다.\n"

#: src/oremind.cpp:256
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"이 프로젝트는 무비판적 MIT식 라이선스와 정치적으로 순진한 BSD식 라이선스를 거"
"부합니다.\n"

#: src/oremind.cpp:259
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "법이 허용하는 범위에서 어떠한 보증도 없습니다.\n"

