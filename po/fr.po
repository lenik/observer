#: src/oremind.cpp:107
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"Utilisation : ou rappeler [OPTION]...\n"
"Exécutez une invite d’auto-observation du bureau en arrière-plan.\n"

#: src/oremind.cpp:112
msgid "repeat for more verbose loggings\n"
msgstr "repeter pour obtenir des journaux plus verbeux\n"

#: src/oremind.cpp:114
msgid "show less logging messages\n"
msgstr "afficher moins de messages de journal\n"

#: src/oremind.cpp:116
msgid "display this help and exit\n"
msgstr "afficher cette aide et quitter\n"

#: src/oremind.cpp:118
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr ""
"définir l'interface utilisateur locale, par exemple zh_CN, ja, ko, en\n"

#: src/oremind.cpp:120
msgid "set theme: light or dark\n"
msgstr "Thème défini : clair ou sombre\n"

#: src/oremind.cpp:122
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "définir le pourcentage final d’opacité de la fenêtre, de 0 à 100\n"

#: src/oremind.cpp:124
msgid "exit after NUM consecutive cancels\n"
msgstr "quitter apres NUM annulations consecutives\n"

#: src/oremind.cpp:126
msgid "set prompt interval in minutes\n"
msgstr "définir l'intervalle d'invite en minutes\n"

#: src/oremind.cpp:128
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr ""
"définir le début de semaine du calendrier : M/m pour lundi, S/s pour "
"dimanche\n"

#: src/oremind.cpp:130
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr ""
"Chemin du fichier SQLite ou répertoire de journaux lorsque PATH est un "
"répertoire\n"

#: src/oremind.cpp:132
msgid "output version information and exit\n"
msgstr "afficher les informations de version et quitter\n"

