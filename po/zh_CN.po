#: src/oremind.cpp:108
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"用法：oremind [选项]...\n"
"在后台运行桌面自我观察提示器。\n"

#: src/oremind.cpp:113
msgid "repeat for more verbose loggings\n"
msgstr "重复使用以输出更多详细日志\n"

#: src/oremind.cpp:115
msgid "show less logging messages\n"
msgstr "显示更少的日志消息\n"

#: src/oremind.cpp:117
msgid "display this help and exit\n"
msgstr "显示此帮助并退出\n"

#: src/oremind.cpp:119
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr "设置界面语言，例如 zh_CN、ja、ko、en\n"

#: src/oremind.cpp:121
msgid "set theme: light or dark\n"
msgstr "设置主题：light 或 dark\n"

#: src/oremind.cpp:123
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "设置弹窗最终不透明度百分比，范围 0 到 100\n"

#: src/oremind.cpp:125
msgid "set prompt interval in minutes\n"
msgstr "设置提示间隔，单位为分钟\n"

#: src/oremind.cpp:127
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr "设置日历周起始日：M/m 表示周一，S/s 表示周日\n"

#: src/oremind.cpp:129
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr "SQLite 文件路径；如果 PATH 是目录，则作为日志目录\n"

#: src/oremind.cpp:131
msgid "output version information and exit\n"
msgstr "输出版本信息并退出\n"

#: src/oremind.cpp:133
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "报告问题到：<%s>\n"

#: src/oremind.cpp:179
#, c-format
msgid "invalid locale: %s\n"
msgstr "无效语言区域：%s\n"

#: src/oremind.cpp:187
#, c-format
msgid "expect theme name.\n"
msgstr "需要主题名称。\n"

#: src/oremind.cpp:193
#, c-format
msgid "invalid theme: %s\n"
msgstr "无效主题：%s\n"

#: src/oremind.cpp:204
#, c-format
msgid "invalid opacity: %s\n"
msgstr "无效不透明度：%s\n"

#: src/oremind.cpp:215
#, c-format
msgid "invalid interval: %s\n"
msgstr "无效间隔：%s\n"

#: src/oremind.cpp:227
#, c-format
msgid "invalid week start: %s\n"
msgstr "无效周起始日：%s\n"

#: src/oremind.cpp:236
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "版权所有 (C) %d %s\n"

#: src/oremind.cpp:237
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"许可证 AGPL-3.0-or-later：<https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:239
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "这是自由软件：你可以自由修改并重新分发。\n"

#: src/oremind.cpp:241
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "本项目反对 AI 剥削与 AI 霸权。\n"

#: src/oremind.cpp:242
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr "本项目拒绝无脑 MIT 式许可和政治幼稚的 BSD 式许可。\n"

#: src/oremind.cpp:245
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "在法律允许范围内，不提供任何担保。\n"

