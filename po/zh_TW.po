#: src/oremind.cpp:108
msgid ""
"Usage: oremind [OPTION]...\n"
"Run a desktop self-observation prompt in the background.\n"
msgstr ""
"用法：oremind [選項]...\n"
"在後臺執行桌面自我觀察提示器。\n"

#: src/oremind.cpp:113
msgid "repeat for more verbose loggings\n"
msgstr "重複使用以顯示更多詳細日誌\n"

#: src/oremind.cpp:115
msgid "show less logging messages\n"
msgstr "顯示較少的日誌訊息\n"

#: src/oremind.cpp:117
msgid "display this help and exit\n"
msgstr "顯示此說明並結束\n"

#: src/oremind.cpp:119
msgid "set UI locale, for example zh_CN, ja, ko, en\n"
msgstr "設定介面語言，例如 zh_CN、ja、ko、en\n"

#: src/oremind.cpp:121
msgid "set theme: light or dark\n"
msgstr "設定主題：light 或 dark\n"

#: src/oremind.cpp:123
msgid "set final dialog opacity percentage, 0 to 100\n"
msgstr "設定彈窗最終不透明度百分比，範圍 0 到 100\n"

#: src/oremind.cpp:125
msgid "exit after NUM consecutive cancels\n"
msgstr "連續取消 NUM 次後退出\n"

#: src/oremind.cpp:127
msgid "set prompt interval in minutes\n"
msgstr "設定提示間隔，單位為分鐘\n"

#: src/oremind.cpp:129
msgid "set calendar week start: M/m for Monday, S/s for Sunday\n"
msgstr "設定日曆週起始日：M/m 表示週一，S/s 表示週日\n"

#: src/oremind.cpp:131
msgid "SQLite file path, or log directory when PATH is a directory\n"
msgstr "SQLite 檔案路徑；如果 PATH 是目錄，則作為日誌目錄\n"

#: src/oremind.cpp:133
msgid "output version information and exit\n"
msgstr "輸出版本資訊並結束\n"

#: src/oremind.cpp:135
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "回報問題到：<%s>\n"

#: src/oremind.cpp:182
#, c-format
msgid "invalid locale: %s\n"
msgstr "無效語言區域：%s\n"

#: src/oremind.cpp:190
#, c-format
msgid "expect theme name.\n"
msgstr "需要主題名稱。\n"

#: src/oremind.cpp:196
#, c-format
msgid "invalid theme: %s\n"
msgstr "無效主題：%s\n"

#: src/oremind.cpp:207
#, c-format
msgid "invalid opacity: %s\n"
msgstr "無效不透明度：%s\n"

#: src/oremind.cpp:218
#, c-format
msgid "invalid cancel count: %s\n"
msgstr "無效取消次數：%s\n"

#: src/oremind.cpp:229
#, c-format
msgid "invalid interval: %s\n"
msgstr "無效間隔：%s\n"

#: src/oremind.cpp:241
#, c-format
msgid "invalid week start: %s\n"
msgstr "無效週起始日：%s\n"

#: src/oremind.cpp:250
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "版權所有 (C) %d %s\n"

#: src/oremind.cpp:251
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr "授權 AGPL-3.0-or-later：<https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/oremind.cpp:253
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "這是自由軟體：你可以自由修改並再散布。\n"

#: src/oremind.cpp:255
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "本專案反對 AI 剝削與 AI 霸權。\n"

#: src/oremind.cpp:256
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr "本專案反對無腦 MIT 式授權與政治愚蠢 BSD 式授權。\n"

#: src/oremind.cpp:259
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "在法律允許範圍內，不提供任何保證。\n"

