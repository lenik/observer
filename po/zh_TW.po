#: src/QuoteProvider.cpp:9
msgid "明天是今天的延续，今天是明天的提前。"
msgstr "明天是今天的延續，今天是明天的提前。"

#: src/QuoteProvider.cpp:10
msgid "中低电量，也要推进一个最小动作。"
msgstr "中低電量，也要推進一個最小動作。"

#: src/QuoteProvider.cpp:11
msgid "不要创造刺激，先创造价值。"
msgstr "不要創造刺激，先創造價值。"

#: src/QuoteProvider.cpp:12
msgid "高维空转会成为利息税。"
msgstr "高維空轉會成為利息稅。"

#: src/QuoteProvider.cpp:13
msgid "接地，不是放弃理想，是把理想接到地面。"
msgstr "接地，不是放棄理想，是把理想接到地面。"

#: src/QuoteProvider.cpp:14
msgid "现在不是证明自己伟大，而是完成下一步。"
msgstr "現在不是證明自己偉大，而是完成下一步。"

#: src/QuoteProvider.cpp:15
msgid "把当前状态记录下来，就是重新夺回方向盘。"
msgstr "把當前狀態記錄下來，就是重新奪回方向盤。"

#: src/QuoteProvider.cpp:16
msgid "疲惫时不要规划人生，先完成一个小动作。"
msgstr "疲憊時不要規劃人生，先完成一個小動作。"

#: src/QuoteProvider.cpp:17
msgid "真正的执行，不依赖情绪同意。"
msgstr "真正的執行，不依賴情緒同意。"

#: src/QuoteProvider.cpp:18
msgid "空想可以点火，但落地才能发电。"
msgstr "空想可以點火，但落地才能發電。"

#: src/QuoteProvider.cpp:19
msgid "不要等状态好，状态是在行动中恢复的。"
msgstr "不要等狀態好，狀態是在行動中恢復的。"

#: src/QuoteProvider.cpp:20
msgid "先把手放到事情上，心会慢慢跟上。"
msgstr "先把手放到事情上，心會慢慢跟上。"

#: src/QuoteProvider.cpp:21
msgid "焦虑不是命令，它只是噪音。"
msgstr "焦慮不是命令，它只是噪音。"

#: src/QuoteProvider.cpp:22
msgid "今天不用赢世界，只要赢一次漂移。"
msgstr "今天不用贏世界，只要贏一次漂移。"

#: src/QuoteProvider.cpp:23
msgid "能量低，就把任务切到更小。"
msgstr "能量低，就把任務切到更小。"

#: src/QuoteProvider.cpp:24
msgid "接地的第一步，是说清我现在在干嘛。"
msgstr "接地的第一步，是說清我現在在幹嘛。"

#: src/QuoteProvider.cpp:25
msgid "记录不是浪费时间，记录是在校准方向。"
msgstr "記錄不是浪費時間，記錄是在校準方向。"

#: src/QuoteProvider.cpp:26
msgid "不必立刻强大，但要立刻靠近现实。"
msgstr "不必立刻強大，但要立刻靠近現實。"

#: src/QuoteProvider.cpp:27
msgid "世界不会因为你想明白才开始运转。"
msgstr "世界不會因為你想明白才開始運轉。"

#: src/QuoteProvider.cpp:28
msgid "先做可见的一步，再谈宏大的结构。"
msgstr "先做可見的一步，再談宏大的結構。"

#: src/QuoteProvider.cpp:29
msgid "把想法压进动作里，它才会变成力量。"
msgstr "把想法壓進動作裡，它才會變成力量。"

#: src/QuoteProvider.cpp:30
msgid "拖延不是失败，但不观察拖延会变成系统。"
msgstr "拖延不是失敗，但不觀察拖延會變成系統。"

#: src/QuoteProvider.cpp:31
msgid "今天的最小闭环，就是明天的支点。"
msgstr "今天的最小閉環，就是明天的支點。"

#: src/QuoteProvider.cpp:32
msgid "不要追求完美启动，追求真实启动。"
msgstr "不要追求完美啟動，追求真實啟動。"

#: src/QuoteProvider.cpp:33
msgid "当前这一分钟，比想象中的未来更有权重。"
msgstr "當前這一分鐘，比想象中的未來更有權重。"

#: src/QuoteProvider.cpp:34
msgid "不要用复杂性保护逃避。"
msgstr "不要用複雜性保護逃避。"

#: src/QuoteProvider.cpp:35
msgid "把混乱写下来，混乱就开始失去权力。"
msgstr "把混亂寫下來，混亂就開始失去權力。"

#: src/QuoteProvider.cpp:36
msgid "接地值下降时，先回到手边的任务。"
msgstr "接地值下降時，先回到手邊的任務。"

#: src/QuoteProvider.cpp:37
msgid "能量值不是道德评分，它只是仪表盘。"
msgstr "能量值不是道德評分，它只是儀表盤。"

#: src/QuoteProvider.cpp:38
msgid "心情值不是结论，它只是天气。"
msgstr "心情值不是結論，它只是天氣。"

#: src/QuoteProvider.cpp:39
msgid "低心情时，不要做终局判断。"
msgstr "低心情時，不要做終局判斷。"

#: src/QuoteProvider.cpp:40
msgid "低能量时，不要否定整个人生。"
msgstr "低能量時，不要否定整個人生。"

#: src/QuoteProvider.cpp:41
msgid "低接地时，不要相信宏大冲动。"
msgstr "低接地時，不要相信宏大沖動。"

#: src/QuoteProvider.cpp:42
msgid "先问：我现在能完成什么？"
msgstr "先問：我現在能完成什麼？"

#: src/QuoteProvider.cpp:43
msgid "事情不是靠感动完成的，是靠连续动作完成的。"
msgstr "事情不是靠感動完成的，是靠連續動作完成的。"

#: src/QuoteProvider.cpp:44
msgid "少一点解释自己，多一点移动棋子。"
msgstr "少一點解釋自己，多一點移動棋子。"

#: src/QuoteProvider.cpp:45
msgid "真正的自由，来自可重复的执行能力。"
msgstr "真正的自由，來自可重複的執行能力。"

#: src/QuoteProvider.cpp:46
msgid "把今天变成证据，而不是幻想。"
msgstr "把今天變成證據，而不是幻想。"

#: src/QuoteProvider.cpp:47
msgid "你不需要燃烧，你需要稳定供电。"
msgstr "你不需要燃燒，你需要穩定供電。"

#: src/QuoteProvider.cpp:48
msgid "别让大目标吃掉小动作。"
msgstr "別讓大目標吃掉小動作。"

#: src/QuoteProvider.cpp:49
msgid "现实不是敌人，现实是接口。"
msgstr "現實不是敵人，現實是介面。"

#: src/QuoteProvider.cpp:50
msgid "最好的灵感，是能进入下一步的灵感。"
msgstr "最好的靈感，是能進入下一步的靈感。"

#: src/QuoteProvider.cpp:51
msgid "不要把思考当成完成。"
msgstr "不要把思考當成完成。"

#: src/QuoteProvider.cpp:52
msgid "不要把紧张当成努力。"
msgstr "不要把緊張當成努力。"

#: src/QuoteProvider.cpp:53
msgid "不要把收藏当成学习。"
msgstr "不要把收藏當成學習。"

#: src/QuoteProvider.cpp:54
msgid "不要把计划当成推进。"
msgstr "不要把計劃當成推進。"

#: src/QuoteProvider.cpp:55
msgid "不要把焦虑当成责任感。"
msgstr "不要把焦慮當成責任感。"

#: src/QuoteProvider.cpp:56
msgid "不要把兴奋当成成果。"
msgstr "不要把興奮當成成果。"

#: src/QuoteProvider.cpp:57
msgid "真正的进展，会留下痕迹。"
msgstr "真正的進展，會留下痕跡。"

#: src/QuoteProvider.cpp:58
msgid "今天至少留下一条可验证的痕迹。"
msgstr "今天至少留下一條可驗證的痕跡。"

#: src/QuoteProvider.cpp:59
msgid "没有闭环的忙碌，会慢慢变成幻觉。"
msgstr "沒有閉環的忙碌，會慢慢變成幻覺。"

#: src/QuoteProvider.cpp:60
msgid "一件事落地，胜过十个宏大判断。"
msgstr "一件事落地，勝過十個宏大判斷。"

#: src/QuoteProvider.cpp:61
msgid "先交付一个粗糙版本，再优化尊严。"
msgstr "先交付一個粗糙版本，再最佳化尊嚴。"

#: src/QuoteProvider.cpp:62
msgid "把任务做到能被别人看见。"
msgstr "把任務做到能被別人看見。"

#: src/QuoteProvider.cpp:63
msgid "把想法做到能被自己复盘。"
msgstr "把想法做到能被自己覆盤。"

#: src/QuoteProvider.cpp:64
msgid "重复不是低级，重复是系统成形的方式。"
msgstr "重複不是低階，重複是系統成形的方式。"

#: src/QuoteProvider.cpp:65
msgid "节奏比爆发更可靠。"
msgstr "節奏比爆發更可靠。"

#: src/QuoteProvider.cpp:66
msgid "你不是没方向，你是需要重新对焦。"
msgstr "你不是沒方向，你是需要重新對焦。"

#: src/QuoteProvider.cpp:67
msgid "漂移不可怕，不回看才可怕。"
msgstr "漂移不可怕，不回看才可怕。"

#: src/QuoteProvider.cpp:68
msgid "观察自己，不是审判自己。"
msgstr "觀察自己，不是審判自己。"

#: src/QuoteProvider.cpp:69
msgid "状态差时，降低难度，不要取消行动。"
msgstr "狀態差時，降低難度，不要取消行動。"

#: src/QuoteProvider.cpp:70
msgid "把自己从情绪里捞出来，放回任务里。"
msgstr "把自己從情緒裡撈出來，放回任務裡。"

#: src/QuoteProvider.cpp:71
msgid "不要在脑内开会，打开文件。"
msgstr "不要在腦內開會，開啟檔案。"

#: src/QuoteProvider.cpp:72
msgid "不要在脑内创业，发出一个请求。"
msgstr "不要在腦內創業，發出一個請求。"

#: src/QuoteProvider.cpp:73
msgid "不要在脑内复盘，写下一句话。"
msgstr "不要在腦內覆盤，寫下一句話。"

#: src/QuoteProvider.cpp:74
msgid "把注意力从评价切回动作。"
msgstr "把注意力從評價切回動作。"

#: src/QuoteProvider.cpp:75
msgid "能做一点，就先做一点。"
msgstr "能做一點，就先做一點。"

#: src/QuoteProvider.cpp:76
msgid "一点点不是安慰，一点点是入口。"
msgstr "一點點不是安慰，一點點是入口。"

#: src/QuoteProvider.cpp:77
msgid "入口比宏图重要。"
msgstr "入口比宏圖重要。"

#: src/QuoteProvider.cpp:78
msgid "启动比姿势重要。"
msgstr "啟動比姿勢重要。"

#: src/QuoteProvider.cpp:79
msgid "完成比解释重要。"
msgstr "完成比解釋重要。"

#: src/QuoteProvider.cpp:80
msgid "复盘比自责重要。"
msgstr "覆盤比自責重要。"

#: src/QuoteProvider.cpp:81
msgid "今天的执行，是给明天的自己铺路。"
msgstr "今天的執行，是給明天的自己鋪路。"

#: src/QuoteProvider.cpp:82
msgid "人会漂，系统要拉你回来。"
msgstr "人會漂，系統要拉你回來。"

#: src/QuoteProvider.cpp:83
msgid "当你不知道做什么，就记录现在。"
msgstr "當你不知道做什麼，就記錄現在。"

#: src/QuoteProvider.cpp:84
msgid "当你想逃避，就缩小任务。"
msgstr "當你想逃避，就縮小任務。"

#: src/QuoteProvider.cpp:85
msgid "当你想证明，就先交付。"
msgstr "當你想證明，就先交付。"

#: src/QuoteProvider.cpp:86
msgid "当你想放弃，就先暂停判断。"
msgstr "當你想放棄，就先暫停判斷。"

#: src/QuoteProvider.cpp:87
msgid "当你想空转，就问现实接口在哪里。"
msgstr "當你想空轉，就問現實介面在哪裡。"

#: src/QuoteProvider.cpp:88
msgid "别急着寻找意义，先制造一个可用结果。"
msgstr "別急著尋找意義，先製造一個可用結果。"

#: src/QuoteProvider.cpp:89
msgid "意义不是想出来的，是被行动压实的。"
msgstr "意義不是想出來的，是被行動壓實的。"

#: src/QuoteProvider.cpp:90
msgid "稳定的小动作，会慢慢长成命运。"
msgstr "穩定的小動作，會慢慢長成命運。"

#: src/QuoteProvider.cpp:91
msgid "让今天有一个干净的切口。"
msgstr "讓今天有一個乾淨的切口。"

#: src/QuoteProvider.cpp:92
msgid "让任务小到无法拒绝。"
msgstr "讓任務小到無法拒絕。"

#: src/QuoteProvider.cpp:93
msgid "让记录诚实到无法欺骗。"
msgstr "讓記錄誠實到無法欺騙。"

#: src/QuoteProvider.cpp:94
msgid "让系统温柔到可以持续。"
msgstr "讓系統溫柔到可以持續。"

#: src/QuoteProvider.cpp:95
msgid "让行动具体到可以开始。"
msgstr "讓行動具體到可以開始。"

#: src/QuoteProvider.cpp:96
msgid "别和疲惫争辩，给它一个小任务。"
msgstr "別和疲憊爭辯，給它一個小任務。"

#: src/QuoteProvider.cpp:97
msgid "别和焦虑辩论，给它一个时间盒。"
msgstr "別和焦慮辯論，給它一個時間盒。"

#: src/QuoteProvider.cpp:98
msgid "别和空虚对抗，给它一个现实动作。"
msgstr "別和空虛對抗，給它一個現實動作。"

#: src/QuoteProvider.cpp:99
msgid "能量会波动，结构要稳定。"
msgstr "能量會波動，結構要穩定。"

#: src/QuoteProvider.cpp:100
msgid "心情会波动，记录要稳定。"
msgstr "心情會波動，記錄要穩定。"

#: src/QuoteProvider.cpp:101
msgid "接地会波动，提醒要稳定。"
msgstr "接地會波動，提醒要穩定。"

#: src/QuoteProvider.cpp:102
msgid "每一次记录，都是一次返航。"
msgstr "每一次記錄，都是一次返航。"

#: src/QuoteProvider.cpp:103
msgid "每一次提交，都是一次落子。"
msgstr "每一次提交，都是一次落子。"

#: src/QuoteProvider.cpp:104
msgid "每一次接地，都是一次回到现实。"
msgstr "每一次接地，都是一次回到現實。"

#: src/QuoteProvider.cpp:105
msgid "不要轻看两分钟，它能切断一整天的漂移。"
msgstr "不要輕看兩分鐘，它能切斷一整天的漂移。"

#: src/QuoteProvider.cpp:106
msgid "观察不是为了控制一切，而是为了不被一切拖走。"
msgstr "觀察不是為了控制一切，而是為了不被一切拖走。"

#: src/QuoteProvider.cpp:107
msgid "今天只问三个数和一句话。"
msgstr "今天只問三個數和一句話。"

#: src/QuoteProvider.cpp:108
msgid "你现在在哪里？你正在做什么？你还要不要回来？"
msgstr "你現在在哪裡？你正在做什麼？你還要不要回來？"

